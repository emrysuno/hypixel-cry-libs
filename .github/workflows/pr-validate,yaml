name: Auto-Update Library Registry
on:
  push:
    branches: ['main']
  pull_request:
    branches: ['main']
    types: [opened, reopened, synchronize]
    paths:
      - '**/*.lua'

jobs:
  update-registry:
    runs-on: ubuntu-latest
    permissions:
      contents: write # Required to push the updated JSON back to the branch

    steps:
      - name: Checkout PR Branch
        uses: actions/checkout@v4
        with:
          # pull_request_target checks out base by default; we need the PR head
          ref: ${{ github.event.pull_request.head.ref }}
          repository: ${{ github.event.pull_request.head.repo.full_name }}
          # Need full history to perform a diff against the base branch
          fetch-depth: 0

      - name: Install Luacheck & jq
        run: |
          sudo apt-get update
          sudo apt-get install -y luacheck jq

      - name: Process New Libraries and Update JSON
        run: |
          # Ensure registry.json exists
          if [ ! -f "registry.json" ]; then
            echo "[]" > registry.json
          fi

          # Fetch the base branch so we can compare
          git fetch origin ${{ github.base_ref }}

          # Get list of new/modified Lua files
          CHANGED_FILES=$(git diff --name-only origin/${{ github.base_ref }} HEAD | grep '\.lua$' || true)

          if [ -z "$CHANGED_FILES" ]; then
            echo "No relevant Lua files found."
            exit 0
          fi

          for FILE in $CHANGED_FILES; do
            if [ ! -f "$FILE" ]; then continue; fi
            
            echo "Linting $FILE..."
            luacheck "$FILE" --no-color

            # Data Extraction
            FILE_MD5=$(md5sum "$FILE" | awk '{print $1}')
            FILE_NAME=$(basename "$FILE")
            
            # Extract metadata from comments (e.g., -- @version 1.2)
            FILE_VER=$(grep -oP '^--\s*@version\s+\K.*' "$FILE" || echo "alpha-0.1")
            FILE_LOC=$(grep -oP '^--\s*@location\s+\K.*' "$FILE" || echo "/libs/")

            echo "Updating registry for $FILE_NAME (MD5: $FILE_MD5)"

            # Update the JSON array: remove old entry by name, add new entry
            jq --arg name "$FILE_NAME" \
               --arg md5 "$FILE_MD5" \
               --arg loc "$FILE_LOC" \
               --arg ver "$FILE_VER" \
               'map(select(.name != $name)) + [{name: $name, md5: $md5, location: $loc, ver: $ver}]' \
               registry.json > tmp.json && mv tmp.json registry.json
          done

      - name: Commit Updated Registry
        uses: stefanzweifel/git-auto-commit-action@v5
        with:
          commit_message: "chore: auto-update registry for ${{ github.event.pull_request.title }}"
          file_pattern: "registry.json"
          # Ensures the commit is attributed to the action bot
          commit_user_name: github-actions[bot]
          commit_user_email: github-actions[bot]@users.noreply.github.com
